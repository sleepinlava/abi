# ABI Docker ignore — exclude files not needed in build context
__pycache__
*.pyc
.pytest_cache
.ruff_cache
.mypy_cache
.git
.gitignore
*.egg-info
docs/_build
tests/
# Dockerfiles and docker/.condarc are part of the build inputs. Do not ignore
# them: every plugin Dockerfile copies docker/.condarc into the image.
.claude/
.codex/
baseline_comparison/
demo_artifacts/
# golden_traces/ and examples/ needed by pyproject.toml force-include at build time
experiments/
docs/superpowers/
bench/
data/benchmark/
data/validation/
abi-databases/
*.log
progress.json
progress.jsonl
# envs/*.yml are generated from environments.yaml, but they are required build
# inputs for the plugin images and therefore must remain in the build context.
# SciPlot test artifacts
src/abi/sciplot/tests/_output/
