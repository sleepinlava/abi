{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["plugin", "sample_count", "samples", "artifacts", "commands", "versions"],
  "properties": {
    "plugin": {"const": "easymetagenome"},
    "sample_count": {"type": "integer", "minimum": 1},
    "samples": {"type": "array"},
    "artifacts": {"type": "object"},
    "commands": {"type": "array"},
    "versions": {"type": "array"}
  }
}
